<Window x:Class="ArchRender.Revit.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ArchRender Settings"
        Width="440" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1a1a1a"
        FontFamily="Segoe UI" FontSize="13">

  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="#f3f4f6"/>
    </Style>
    <Style TargetType="Button">
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </Window.Resources>

  <StackPanel Margin="24">

    <TextBlock Text="ArchRender Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

    <TextBlock Text="API Key" Foreground="#9ca3af" Margin="0,0,0,6"/>
    <TextBlock TextWrapping="Wrap" Foreground="#6b7280" FontSize="11" Margin="0,0,0,8">
      Generate an API key in your ArchRender account under Settings → API Keys.
    </TextBlock>
    <PasswordBox x:Name="ApiKeyBox" Background="#2d2d2d" Foreground="#f3f4f6"
                 BorderBrush="#3d3d3d" Padding="8,6"
                 PasswordChar="*"/>

    <TextBlock x:Name="StatusText" Margin="0,10,0,0" TextWrapping="Wrap"
               Foreground="#4ade80" Visibility="Collapsed"/>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
      <Button Content="Clear Key" Background="#374151" Foreground="White"
              Margin="0,0,8,0" Click="ClearKey_Click"/>
      <Button Content="Cancel" Background="#374151" Foreground="White"
              Margin="0,0,8,0" Click="Cancel_Click"/>
      <Button Content="Save" Background="#2563eb" Foreground="White"
              Click="Save_Click"/>
    </StackPanel>

  </StackPanel>
</Window>
